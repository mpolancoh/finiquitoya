# ─── FiniquitoYa — Required Environment Variables ───────────────────────────
# Copy this file to .env.local for local development.
# In production, set these in the Vercel dashboard under Project → Settings → Environment Variables.
# NEVER commit .env.local or any .env.* file with real values.

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for local dev, sk_live_... for production ONLY.
STRIPE_SECRET_KEY=sk_live_...

# Get from: https://dashboard.stripe.com/webhooks → select your endpoint → Signing secret
# For local testing, use the secret from `stripe listen` (starts with whsec_).
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Brevo (Sendinblue) — Transactional Email ──────────────────────────────────
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...

# Admin email for payment notifications
ADMIN_EMAIL=you@example.com

# ── Google Sheets — Transaction Log ──────────────────────────────────────────
# Create a Service Account at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Download the JSON key and paste the entire JSON string here (as a single line).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# The spreadsheet ID from the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_ID=1abc...

# ── Upstash Redis — Rate Limiting + Webhook Idempotency ───────────────────────
# Create a free database at: https://upstash.com → Redis → Create Database
# Copy the REST URL and REST Token from the database dashboard.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ── Sentry — Error Monitoring ─────────────────────────────────────────────────
# Create a Node.js project at: https://sentry.io → Projects → Create Project → Node.js
# Copy the DSN from: Project Settings → Client Keys (DSN)
SENTRY_DSN=https://abc123@o0.ingest.sentry.io/0

# ── App URL (optional) ────────────────────────────────────────────────────────
# If set, used to build Stripe success/cancel redirect URLs.
# Vercel sets x-forwarded-host automatically, so this is only needed for custom setups.
# APP_URL=https://finiquitoya.app
